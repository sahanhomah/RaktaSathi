# Copy this file to .env and fill with your real values.
# .env is loaded automatically by bloodbank/settings.py

# Email OTP (real inbox delivery)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=your_email@gmail.com

# Optional explicit backend (usually not required)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMS (optional)
SMS_DEMO_MODE=True
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
